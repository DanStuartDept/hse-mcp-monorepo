{
  "name": "@danstuartdept/hse-servicefinder-mcp",
  "version": "1.3.0",
  "description": "MCP server for the HSE Service Finder API — Ireland's public health service directory",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "hse-servicefinder-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanStuartDept/hse-servicefinder-mcp.git"
  },
  "publishConfig": {
    "@danstuartdept:registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector node build/index.js"
  },
  "keywords": [
    "mcp",
    "hse",
    "health",
    "ireland",
    "service-finder"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
